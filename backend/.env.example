DATABASE_URL=postgresql+asyncpg://territory:territory@localhost:55432/territory
AUTH_DISABLED_FOR_LOCAL_DEV=true
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_AUDIENCE=
ENTRA_ISSUER=
CENSUS_BATCH_URL=https://geocoding.geo.census.gov/geocoder/locations/addressbatch
GEOCODE_CHUNK_SIZE=10000
IMPORT_WORKER_CONCURRENCY=1
ASSIGNMENT_EVENT_RETENTION_DAYS=548

  # Oracle (XXATDAR_DC_REG_MKT_TBL). Empty = live endpoints return 503.
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_DSN=host:1521/service
ORACLE_POOL_MIN=1
ORACLE_POOL_MAX=4

# prod-msa REST for live customer-location data.
MSA_BASE_URL=https://prod-msa.gcp.atd-us.com
MSA_TIMEOUT_SECONDS=15.0
MSA_CACHE_TTL_SECONDS=300
